# sVault backend — copy to .env and fill. NEVER commit real values.

ENV=dev
DEBUG=true
LOG_LEVEL=INFO

# Supabase — use the TRANSACTION POOLER (Supavisor) URL on serverless (port 6543), not direct.
DATABASE_URL=postgresql+asyncpg://postgres.hgopttbpoyvmlzgzyzio:[PASSWORD]@aws-0-<region>.pooler.supabase.com:6543/postgres
SUPABASE_URL=https://hgopttbpoyvmlzgzyzio.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Scheduling timezone
TIMEZONE=Asia/Kolkata

# Observability
SENTRY_DSN=

